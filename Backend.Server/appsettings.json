{
  "PayrollServerConfiguration": {
    // culture
    //"StartupCulture": "en-US",

    // audit trail configuration
    "AuditTrail": {
      // enable audit trail fro scripts (default: false)
      //"Script": false,
      // enable audit trail for lookup and lookup values (default: false)
      //"Lookup": false,
      // enable audit trail for case, case field and case relation (default: false)
      //"Input": false,
      // enable audit trail for collector and wage type (default: false)
      //"Payrun": false,
      // enable audit trail for report, report template and report parameter (default: false)
      //"Report": false
    },

    // log http requests (default: false)
    //"LogHttpRequests": true,

    // initialize the script compiler to reduce first execution time (default: false)
    //"InitializeScriptCompiler": true,

    // Dump compiler source files (default: false)
    //"DumpCompilerSources": true,

    // Static safety analysis of scripts during compilation (default: false)
    // Blocks banned APIs (System.IO, System.Net, System.Diagnostics, System.Reflection, etc.)
    // Enable to harden script execution against unauthorized BCL access
    //"ScriptSafetyAnalysis": false,

    // Webhook timeout (default: 1 minute)
    //"WebhookTimeout": "00:02:30",

    // Function log timeout (default: off)
    //"FunctionLogTimeout" : "00:00:00.000",

    // Database provider: SqlServer (default) | MySql
    //"DbProvider": "SqlServer",

    // Database command timeout in seconds (default: 2 minutes)
    //"DbCommandTimeout": 00:02:00,

    // database transaction timeout (default: 10 minutes)
    //"DbTransactionTimeout" : "00:10:00",

    // Required database collation -- SQL Server only (default: SQL_Latin1_General_CP1_CS_AS)
    //"DbCollation": "SQL_Latin1_General_CP1_CS_AS",

    // assembly cache timeout (default: 30 minutes)
    //"AssemblyCacheTimeout" : "00:30:00",

    // maximum degree of parallelism for employee processing.
    // null or empty or 0 = auto (default, based on Environment.ProcessorCount)
    // off or -1 = sequential (no parallelism, useful for debugging)
    // half = half CPU load, good balance
    // max = full CPU utilization; monitor DB load
    // 1 to N = explicit maximum thread count.
    //"MaxParallelEmployees": "off",

    // Log employee processing timing (default: false)
    //"LogEmployeeTiming": false,

    // Maximum degree of parallelism for result persistence (SemaphoreSlim count). Default: 2
    // 1 = fully serialized (no deadlocks, ~30% slower at scale)
    // 2 = default, best balance of throughput and stability (load-tested)
    // 4+ = no measurable gain over 2; not recommended
    //"MaxParallelPersist": 2,

    // swagger documentation
    "XmlCommentFileNames": [
      "PayrollEngine.Core.xml",
      "PayrollEngine.Domain.Model.xml",
      "PayrollEngine.Api.Model.xml",
      "PayrollEngine.Backend.Controller.xml",
      "PayrollEngine.Backend.Server.xml"
    ],

    // visible controllers, mask with wildcard support '*' and '?' (default: all)
    "VisibleControllers": [
      //"Tenant",
      //"Payroll"
    ],
    // hidden controllers
    "HiddenControllers": [
      // enable the next line to hide all audit controllers
      //"*Audit"
    ],

    // CORS configuration (default: inactive, no cross-origin requests allowed)
    // AllowedOrigins: specific origins or ["*"] for development only
    // AllowCredentials: true enables cookies/auth headers (incompatible with wildcard origin)
    //"Cors": {
    //  "AllowedOrigins": [ "https://app.example.com", "https://admin.example.com" ],
    //  "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
    //  "AllowedHeaders": [ "Content-Type", "Authorization", "Api-Key", "Auth-Tenant" ],
    //  "AllowCredentials": false,
    //  "PreflightMaxAgeSeconds": 600
    //},

    // rate limiting (default: inactive, PermitLimit 0)
    // Global: applies to all endpoints per client IP
    // PayrunJobStart: applies to POST /api/tenants/{tenantId}/payruns/jobs
    //"RateLimiting": {
    //  "Global": { "PermitLimit": 100, "WindowSeconds": 60 },
    //  "PayrunJobStart": { "PermitLimit": 5, "WindowSeconds": 60 }
    //},

    // Enable Swagger UI and JSON endpoint (default: false)
    // Should be disabled in production environments
    //"EnableSwagger": false,

    // Use swagger dark theme (default: false)
    "DarkTheme": true,

    // Database provider (default: SqlServer). Supported: SqlServer | MySql
    //"DbProvider": "SqlServer",

    "Authentication": {
      // Authentication mode: None | ApiKey | OAuth (default: None)
      "Mode": "None",
      // Authentication key (required on mode ApiKey)
      "ApiKey": "?????????",
      // OAuth 2.0 / JWT Bearer authentication
      "OAuth": {
        // OAuth authority
        "Authority": "http://localhost:8080/realms/payroll",
        // OAuth audience
        "Audience": "payroll-api",
        // OAuth https
        "RequireHttpsMetadata": false,
        // OAuth client secret
        "ClientSecret": "??????????????????????????????"
      }
    }
  },

  // database connections
  "ConnectionStrings": {
    // SQL Server (default, DbProvider=SqlServer)
    //"PayrollDatabaseConnection": "server=localhost; database=PayrollEngine; Integrated Security=SSPI; Connection Timeout=1000",
    // MySQL 8.0+ (DbProvider=MySql)
    //"PayrollDatabaseConnection": "Server=localhost;Port=3306;Database=PayrollEngine;User=payroll;Password=...;CharSet=utf8mb4;"
  },

  // logger
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning"
        // diagnostic: enable payrun phase logging (Trace level)
        // "PayrollEngine.Domain.Application": "Verbose"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "pathWindows": "%PROGRAMDATA%/PayrollEngine/Backend/logs/log-.log",
                "path": "logs/log-.log",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 7,
                "buffered": false
              }
            }
          ]
        }
      },
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  // filter
  "AllowedHosts": "*"
}